# --- Database (Neon Serverless Postgres) ---
# Use the pooled endpoint (hostname contains "-pooler").
# Append `?sslmode=verify-full` — Neon serves valid certs and this silences the
# pg-connection-string deprecation warning that ships with pg 8.x / will change
# semantics in pg 9.
DATABASE_URL=

# --- Payload CMS ---
PAYLOAD_SECRET=
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Stripe (donations) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Shopify (headless storefront) ---
SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# --- AWS (SES + S3) ---
# Note: env vars on AWS Amplify cannot start with the reserved "AWS_" prefix.
# AWS_REGION is auto-set by the Lambda runtime in production.
SES_FROM_EMAIL=
# Optional: where contact form submissions are sent. Falls back to SES_FROM_EMAIL.
CONTACT_TO_EMAIL=
S3_BUCKET_NAME=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
